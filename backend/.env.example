DATABASE_URL=sqlite+aiosqlite:///./immigration.db
SECRET_KEY=change-me-to-a-long-random-secret-key

# Tài khoản admin mặc định (tạo/cập nhật khi khởi động backend)
ADMIN_EMAIL=it.admin@edupath.org.vn
ADMIN_PASSWORD=Edupath@68

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1
# Ước tính chi phí USD / 1M token (tùy model)
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60
# Ngân sách token/tháng (0 = không giới hạn)
MONTHLY_TOKEN_BUDGET=0

UPLOAD_DIR=uploads
EXPORT_DIR=exports
APP_BASE_URL=http://localhost:3000

# Email thông báo (để trống = chỉ thông báo trong app)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@immipath.local
SMTP_USE_TLS=true
