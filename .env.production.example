# === Copy to .env.production and edit before deploy ===
# cp .env.production.example .env.production

# Public URL (domain or IP of your server)
DOMAIN=your-server.example.com
HTTPS_PORT=2026
HTTP_PORT=80
# Truy cập trực tiếp frontend (LAN): http://IP:3000/login
FRONTEND_PORT=3000

# TLS_MODE:
#   internal — self-signed (test / IP, trình duyệt cảnh báo)
#   auto     — Let's Encrypt (cần DOMAIN trỏ DNS + mở port 80)
#   custom   — chứng chỉ có sẵn trong deploy/certs/
TLS_MODE=internal
ACME_EMAIL=admin@your-server.example.com

# PostgreSQL
POSTGRES_USER=immigration
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=immigration_ai

# Backend
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4.1
OPENAI_INPUT_COST_PER_1M=0.15
OPENAI_OUTPUT_COST_PER_1M=0.60
MONTHLY_TOKEN_BUDGET=0

# Admin (tạo/cập nhật khi backend khởi động)
ADMIN_EMAIL=it.admin@edupath.org.vn
ADMIN_PASSWORD=change-me-admin-password

# Email (tùy chọn)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@immipath.local
SMTP_USE_TLS=true
